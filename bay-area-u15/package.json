    "ops:publish:series": "node apps/worker/src/index.js publish-series --config config/leagues.yaml",
    "api:start": "node apps/api/src/server.js",
    "ops:ui:start": "env LOCAL_OPS_ENABLE_UI=true node apps/api/src/server.js",
