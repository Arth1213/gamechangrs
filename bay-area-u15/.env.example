# Primary database connection for local development or cloud deployment.
#
# Recommended project path:
# - local development scratch database: local Postgres
# - shared / source-of-truth database: dedicated Supabase Postgres project
#
# Option A: local Postgres
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/game_changrs_cricket
# DATABASE_SSL_MODE=disable
#
# Option B: Supabase session pooler (recommended default for this Mac if IPv6 is uncertain)
# DATABASE_URL=postgres://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# DATABASE_SSL_MODE=require
#
# Option C: Supabase direct connection (use only if your network supports IPv6)
# DATABASE_URL=postgresql://postgres:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# DATABASE_SSL_MODE=require

DATABASE_URL=
DATABASE_SSL_MODE=require
CORS_ALLOW_ORIGIN=*

# Optional metadata for future app/web integration.
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional override if the schema file moves later.
DATABASE_SCHEMA_PATH=bay_area_u15_schema.sql
