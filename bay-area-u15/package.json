    "worker:profiles:series": "node apps/worker/src/index.js enrich-profiles --config config/leagues.yaml",
    "worker:intelligence:series": "node apps/worker/src/index.js compute-intelligence --config config/leagues.yaml",
    "worker:process-queue": "node apps/worker/src/index.js process-queue --limit 1",
    "worker:process-manual-refresh-queue": "node apps/worker/src/index.js process-manual-refresh-queue --limit 1"
